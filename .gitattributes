# Normalize all text to LF in the repository and on checkout (deterministic across OSes)
* text=auto eol=lf

# Binary assets — never apply EOL conversion
*.png  binary
*.jar  binary
*.keystore binary
*.zip  binary
*.apk  binary
*.so   binary
*.dll  binary
*.exe  binary

# Security payload references contain intentional raw CR / control bytes
# (HTTP request smuggling, CRLF injection, file-upload webshells).
# Preserve them byte-for-byte — do NOT normalize line endings.
skills/pentest-tools/src-hunter/references/payloader/** -text
skills/pentest-tools/src-hunter/references/playbooks/**  -text
